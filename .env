########################################
# Project
########################################

COMPOSE_PROJECT_NAME=lab
PROJECT_NAME=microservices-lab

########################################
# PostgreSQL
########################################

POSTGRES_VERSION=17

POSTGRES_HOST=postgres
POSTGRES_PORT=5433

POSTGRES_DB=user_db

POSTGRES_USER=postgres

POSTGRES_PASSWORD=postgres

########################################
# Redis
########################################

REDIS_VERSION=8

REDIS_PORT=6379

########################################
# RedisInsight
########################################

REDIS_INSIGHT_VERSION=2.70

REDIS_INSIGHT_PORT=5540

########################################
# Kafka
########################################

KAFKA_VERSION=7.8.0

KAFKA_PORT=9092

########################################
# RabbitMQ
########################################

RABBITMQ_VERSION=4-management

RABBITMQ_PORT=5672

RABBITMQ_UI_PORT=15672

########################################
# Keycloak
########################################

KEYCLOAK_VERSION=26.3

KEYCLOAK_PORT=8180

KEYCLOAK_ADMIN=admin

KEYCLOAK_ADMIN_PASSWORD=admin

########################################
# Monitoring
########################################

PROMETHEUS_PORT=9090

GRAFANA_PORT=3000

LOKI_PORT=3100

JAEGER_PORT=16686

OTEL_GRPC_PORT=4317
